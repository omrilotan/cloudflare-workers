    "@parcel/transformer-inline-string": "^2.16.4",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.4.2",
    "jest-environment-miniflare": "^2.14.4",
    "prettier": "^3.9.4",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-toml": "^2.0.6",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "country-code-lookup": "^0.1.5"
